                },
                
                {
                	"bindingName": "clipNomalY",
                	"label":       "clipNomalY",
                	"widget":      "spinbox",
                	"step":        "0.01",
                	"sortIndex":   "0",
                	"hint":        "",
                	"default":     "1.0"
                },
                
                {
                	"bindingName": "clipNomalZ",
                	"label":       "clipNomalZ",
                	"widget":      "spinbox",
                	"step":        "0.01",
                	"sortIndex":   "0",
                	"hint":        "",
                	"default":     "1.0"
                },
                
                {
                	"bindingName": "clipPosX",
                	"label":       "clipPosX",
                	"widget":      "spinbox",
