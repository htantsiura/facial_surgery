                },
                
                {
                	"label": "Sliced",
                	"widget": "group_start"
                },                    
                    {
                    	"bindingName": "slicedHeight",
                    	"label":       "Sliced Height",
                    	"widget":      "slider",
                    	"min":         -5,
                    	"max":         5,
                    	"step":        "0.01",
